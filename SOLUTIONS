-- Apple Sales Project - 1M rows sales datasets

CREATE TABLE category (
    category_id varchar(15) PRIMARY KEY,
    category_name VARCHAR(255) NOT NULL
);


CREATE TABLE product (
    product_id varchar(10) PRIMARY KEY,
    product_name VARCHAR(255) NOT NULL,
    launch_date DATE,
    price FLOAT,
    category_id varchar(15),
    FOREIGN KEY (category_id) REFERENCES category(category_id)
);


CREATE TABLE stores (
    Store_Id varchar(10) PRIMARY KEY,
    store_name VARCHAR(255) NOT NULL,
    location VARCHAR(255)
);



ALTER TABLE stores
CHANGE COLUMN Store_ID store_id VARCHAR(10);



ALTER TABLE store
CHANGE COLUMN location city varchar(100);

ALTER TABLE store
ADD COLUMN country varchar(100);

SET FOREIGN_KEY_CHECKS = 0;
TRUNCATE TABLE store;
SET FOREIGN_KEY_CHECKS = 1;


CREATE TABLE sale (
    sale_id varchar(40) PRIMARY KEY,
    sale_date DATE,
    product_id varchar(10),
    quantity INT,
    store_id varchar(10),
    FOREIGN KEY(store_id) REFERENCES store(store_id)
);

ALTER TABLE sale
CHANGE COLUMN store_ID store_id VARCHAR(10);

CREATE TABLE warranty (
    claim_id varchar(20) PRIMARY KEY,
    claim_date DATE,
    repair_status varchar(30),
    sale_id varchar(10),
    FOREIGN KEY (sale_id) REFERENCES sale(sale_id)
);


