 **Problem 7:** Identify the product category with the most warranty claims filed in the last two years.


SELECT
    c.category_name,
    COUNT(w.claim_id) AS total_claims
FROM category AS c
    JOIN product AS p 
        ON c.category_id = p.category_id
    JOIN sale AS s
        ON p.product_id = s.product_id
    JOIN warranty AS w
        ON s.sale_id = w.sale_id
WHERE w.claim_date >= CURRENT_DATE - INTERVAL 2 YEAR
GROUP BY c.category_name
ORDER BY total_claims DESC
LIMIT 1;

 **Problem 8:** Determine the percentage chance of receiving warranty claims, after each purchase for each country.

SELECT

    country,
    total_sales,
    total_claims,
    COALESCE(total_claims / total_sales * 100, 0)AS percent_of_chance_of_claim
FROM
(SELECT
    st.country,
    SUM(s.quantity) AS total_sales,
    COUNT(w.claim_id) AS total_claims
FROM store AS st
JOIN sale AS s
    ON st.store_id = s.store_id
LEFT JOIN warranty AS w
    ON s.sale_id = w.sale_id
GROUP BY st.country
) AS t1
ORDER BY  COALESCE(total_claims / total_sales * 100, 0) DESC;

 **Problem 9:** Analyze the year-by-year growth ratio for each store.




WITH yearly_sales AS 
(
SELECT
   st.store_id,
   st.store_name,
   YEAR(s.sale_date) AS sale_year,
   SUM(s.quantity *p.price) AS total_sales
FROM store AS st
JOIN sale AS s
    ON st.store_id = s.store_id
JOIN product AS p
    ON p.product_id = s.product_id
GROUP BY st.store_id,st.store_name, YEAR(s.sale_date)
ORDER BY st.store_name, YEAR(s.sale_date)
),

 
yearly_growth AS
 (
SELECT
    store_name,
    sale_year,
    LAG(total_sales, 1) OVER (PARTITION BY store_name ORDER BY YEAR(sale_year)) AS previous_year_sales,
    total_sales AS current_sales
FROM yearly_sales
)
SELECT
    store_name,
    sale_year,
    previous_year_sales,
    current_sales,
    ROUND((current_sales - previous_year_sales) / previous_year_sales * 100, 3) AS growth_ratio
FROM yearly_growth
WHERE previous_year_sales IS NOT NULL AND sale_year <> YEAR(CURRENT_DATE);

